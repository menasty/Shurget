<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Jobs — Shurget Driver</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/theme.css">
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    body{background:#0a0a0a;color:#f8f7f5;font-family:'DM Sans',sans-serif;min-height:100vh}

    /* Header */
    .dh{background:#111;border-bottom:3px solid #ea580c;
        padding:.875rem 1.25rem;display:flex;align-items:center;justify-content:space-between;
        position:sticky;top:0;z-index:60}
    .dh-logo{display:flex;align-items:center;gap:.6rem;text-decoration:none}
    .dh-logo img{height:32px;width:auto}
    .dh-logo span{font-family:'Bebas Neue',sans-serif;font-size:1.6rem;letter-spacing:.12em;color:#fff}
    .dh-name{font-size:.82rem;font-weight:600;color:rgba(255,255,255,.7)}

    /* Layout */
    .wrap{max-width:640px;margin:0 auto;padding:1.25rem 1rem 4rem}

    /* Tabs */
    .tabs{display:flex;gap:.5rem;margin-bottom:1.25rem}
    .tabs a{flex:1;text-align:center;padding:.7rem;border-radius:10px;text-decoration:none;
            font-weight:600;font-size:.85rem;color:rgba(255,255,255,.55);
            background:#111;border:1px solid rgba(255,255,255,.08);transition:all .2s}
    .tabs a:hover{color:#fff;border-color:rgba(234,88,12,.4)}
    .tabs a.active{background:#b84000;color:#fff;border-color:#b84000}

    /* Section heading */
    h1{font-family:'Bebas Neue',sans-serif;font-size:1.8rem;letter-spacing:.08em;
       color:#fff;margin-bottom:1rem}

    /* Job card */
    .card{background:#111;border:1px solid rgba(255,255,255,.08);border-radius:14px;
          padding:1.1rem;margin-bottom:.9rem;transition:border-color .2s}
    .card:hover{border-color:rgba(234,88,12,.35)}
    .card-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:.5rem}
    .item{font-weight:700;font-size:1.05rem;text-transform:capitalize;color:#fff}
    .price{color:#22c55e;font-weight:700;font-size:1.05rem}
    .card-mid{display:flex;justify-content:space-between;align-items:center;margin-bottom:.6rem}
    .addr{font-size:.82rem;color:rgba(255,255,255,.55);line-height:1.5;margin:.2rem 0}
    .addr strong{color:rgba(255,255,255,.8)}

    /* Status badge */
    .badge{display:inline-block;font-size:.65rem;font-weight:700;text-transform:uppercase;
           letter-spacing:.06em;padding:.22rem .6rem;border-radius:6px}
    .badge-assigned{background:rgba(234,88,12,.18);color:#ea580c;border:1px solid rgba(234,88,12,.35)}
    .badge-in_transit{background:rgba(234,88,12,.25);color:#fb923c;border:1px solid rgba(234,88,12,.5)}
    .badge-delivered{background:rgba(34,197,94,.15);color:#22c55e;border:1px solid rgba(34,197,94,.3)}

    /* Action buttons */
    .btn-complete{display:block;width:100%;margin-top:.85rem;padding:.78rem 1rem;
                  background:#b84000;color:#fff;border:none;border-radius:10px;
                  font-family:'DM Sans',sans-serif;font-size:.92rem;font-weight:700;
                  cursor:pointer;transition:background .2s,transform .1s;text-align:center}
    .btn-complete:hover{background:#9e3800}
    .btn-complete:active{transform:scale(.98)}
    .btn-complete:disabled{background:#444;color:rgba(255,255,255,.4);cursor:not-allowed}

    /* Confirm overlay */
    .confirm-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.75);
                     z-index:200;align-items:center;justify-content:center;padding:1rem}
    .confirm-overlay.open{display:flex}
    .confirm-box{background:#1a1a1a;border:1px solid rgba(234,88,12,.4);border-radius:16px;
                 padding:2rem;max-width:360px;width:100%;text-align:center}
    .confirm-box h2{font-family:'Bebas Neue',sans-serif;font-size:1.6rem;letter-spacing:.08em;
                    color:#fff;margin-bottom:.6rem}
    .confirm-box p{font-size:.9rem;color:rgba(255,255,255,.65);margin-bottom:1.4rem;line-height:1.5}
    .confirm-actions{display:flex;gap:.75rem}
    .confirm-yes{flex:1;padding:.75rem;background:#b84000;color:#fff;border:none;
                 border-radius:10px;font-weight:700;cursor:pointer;font-family:'DM Sans',sans-serif;
                 font-size:.92rem;transition:background .2s}
    .confirm-yes:hover{background:#9e3800}
    .confirm-no{flex:1;padding:.75rem;background:transparent;color:rgba(255,255,255,.6);
                border:1px solid rgba(255,255,255,.15);border-radius:10px;font-weight:600;
                cursor:pointer;font-family:'DM Sans',sans-serif;font-size:.92rem;transition:border-color .2s}
    .confirm-no:hover{border-color:rgba(255,255,255,.35);color:#fff}

    /* Toast */
    .toast{position:fixed;bottom:1.5rem;left:50%;transform:translateX(-50%);
           background:#111;border:1px solid rgba(34,197,94,.4);color:#22c55e;
           padding:.7rem 1.4rem;border-radius:10px;font-weight:600;font-size:.88rem;
           opacity:0;transition:opacity .3s;pointer-events:none;z-index:300;white-space:nowrap}
    .toast.show{opacity:1}

    /* Empty state */
    .empty{text-align:center;color:rgba(255,255,255,.4);padding:3rem 1rem;line-height:1.7}
    .empty p+p{margin-top:.5rem}
  </style>
</head>
<body>
  <header class="dh">
    <a href="/" class="dh-logo">
      <img src="/images/shurget-logo-nav.png" alt="Shurget" onerror="this.style.display='none'">
      <span>SHURGET</span>
    </a>
    <span class="dh-name"><%= driver && driver.name ? driver.name : 'Driver' %></span>
  </header>

  <main class="wrap" id="main-content">
    <div class="tabs">
      <a href="/driver/jobs">Available</a>
      <a class="active" href="/driver/my-jobs">My Jobs</a>
    </div>

    <h1>My Jobs</h1>

    <% if (!jobs || jobs.length === 0) { %>
      <div class="empty">
        <p>You have no active jobs right now.</p>
        <p>Check the Available tab to claim a haul.</p>
      </div>
    <% } else { %>
      <% jobs.forEach(function(job){ %>
        <div class="card" id="card-<%= job.id %>">
          <div class="card-top">
            <span class="item"><%= (job.item_type || 'Delivery').replace(/-/g,' ') %></span>
            <span class="price">$<%= Number(job.price_total || 0).toFixed(2) %></span>
          </div>
          <div class="card-mid">
            <span class="badge badge-<%= job.status || 'assigned' %>">
              <%= (job.status || 'assigned').replace(/_/g,' ') %>
            </span>
            <span style="font-size:.8rem;color:rgba(255,255,255,.45)">
              <%= job.distance_miles ? job.distance_miles + ' mi' : '' %>
            </span>
          </div>
          <div class="addr"><strong>Pickup:</strong> <%= job.pickup_address || '—' %></div>
          <div class="addr"><strong>Dropoff:</strong> <%= job.dropoff_address || '—' %></div>
          <% if (job.customer_name) { %>
            <div class="addr"><strong>Customer:</strong> <%= job.customer_name %><%= job.customer_phone ? ' &middot; ' + job.customer_phone : '' %></div>
          <% } %>

          <% if (job.status !== 'delivered') { %>
            <button
              class="btn-complete"
              data-job-id="<%= job.id %>"
              data-item="<%= (job.item_type || 'Delivery').replace(/-/g,' ') %>"
              onclick="promptComplete(this)"
            >
              Mark as Delivered
            </button>
          <% } else { %>
            <div style="margin-top:.75rem;font-size:.8rem;color:#22c55e;font-weight:600;text-align:center">
              Delivery Complete
            </div>
          <% } %>
        </div>
      <% }); %>
    <% } %>
  </main>

  <!-- Confirm overlay -->
  <div class="confirm-overlay" id="confirmOverlay" role="dialog" aria-modal="true" aria-labelledby="confirmTitle">
    <div class="confirm-box">
      <h2 id="confirmTitle">Confirm Delivery</h2>
      <p id="confirmMsg">Has the item been delivered and the customer confirmed receipt?</p>
      <div class="confirm-actions">
        <button class="confirm-no" onclick="closeConfirm()">Cancel</button>
        <button class="confirm-yes" id="confirmYes" onclick="executeComplete()">Yes, Delivered</button>
      </div>
    </div>
  </div>

  <!-- Toast -->
  <div class="toast" id="toast" role="status" aria-live="polite"></div>

  <script>
    let pendingJobId = null;

    function promptComplete(btn) {
      pendingJobId = btn.dataset.jobId;
      const item = btn.dataset.item || 'item';
      document.getElementById('confirmMsg').textContent =
        'Has the ' + item + ' been delivered and the customer confirmed receipt?';
      document.getElementById('confirmOverlay').classList.add('open');
      document.getElementById('confirmYes').focus();
    }

    function closeConfirm() {
      pendingJobId = null;
      document.getElementById('confirmOverlay').classList.remove('open');
    }

    async function executeComplete() {
      if (!pendingJobId) return;
      const jobId = pendingJobId;
      closeConfirm();

      const btn = document.querySelector(`[data-job-id="${jobId}"]`);
      if (btn) { btn.disabled = true; btn.textContent = 'Submitting...'; }

      try {
        const res = await fetch('/driver/jobs/' + jobId + '/complete', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'same-origin',
        });
        const data = await res.json();

        if (res.ok && data.success) {
          // Update badge
          const card = document.getElementById('card-' + jobId);
          const badge = card && card.querySelector('.badge');
          if (badge) {
            badge.className = 'badge badge-delivered';
            badge.textContent = 'delivered';
          }
          if (btn) {
            btn.parentNode.removeChild(btn);
            const done = document.createElement('div');
            done.style.cssText = 'margin-top:.75rem;font-size:.8rem;color:#22c55e;font-weight:600;text-align:center';
            done.textContent = 'Delivery Complete';
            card.appendChild(done);
          }
          showToast('Delivery confirmed. Well done!');
        } else {
          if (btn) { btn.disabled = false; btn.textContent = 'Mark as Delivered'; }
          showToast(data.error || 'Could not update. Try again.', true);
        }
      } catch (err) {
        if (btn) { btn.disabled = false; btn.textContent = 'Mark as Delivered'; }
        showToast('Network error. Check your connection.', true);
      }
    }

    function showToast(msg, isError) {
      const t = document.getElementById('toast');
      t.textContent = msg;
      t.style.borderColor = isError ? 'rgba(239,68,68,.4)' : 'rgba(34,197,94,.4)';
      t.style.color = isError ? '#f87171' : '#22c55e';
      t.classList.add('show');
      setTimeout(() => t.classList.remove('show'), 3500);
    }

    // Close overlay on backdrop click
    document.getElementById('confirmOverlay').addEventListener('click', function(e) {
      if (e.target === this) closeConfirm();
    });

    // Keyboard close
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') closeConfirm();
    });
  </script>
</body>
</html>
