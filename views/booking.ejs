<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Book a Haul - Shurget</title>
  <style>
    body { font-family: system-ui; max-width: 800px; margin: 40px auto; padding: 20px; line-height: 1.6; }
    h1 { color: #ea580c; }
    form { display: grid; gap: 15px; max-width: 600px; }
    label { font-weight: bold; }
    input, select, button { padding: 12px; font-size: 16px; border: 1px solid #ccc; border-radius: 6px; }
    button { background: #ea580c; color: white; border: none; cursor: pointer; font-weight: bold; }
  </style>
</head>
<body>
  <h1>Book a Pickup Truck</h1>
  <p>Get an instant quote and book same-day delivery.</p>

  <form action="/book" method="POST">
    <label>What are you moving?</label>
    <select name="itemType" required>
      <option value="">Select item</option>
      <option value="sofa">Sofa / Couch</option>
      <option value="mattress">Mattress</option>
      <option value="furniture">Furniture</option>
      <option value="appliance">Appliance</option>
      <option value="other">Other</option>
    </select>

    <label>Pickup Address</label>
    <input type="text" name="pickupAddress" placeholder="123 Main St, Castle Rock, CO" required>

    <label>Dropoff Address</label>
    <input type="text" name="dropoffAddress" placeholder="456 Oak Ave, Denver, CO" required>

    <label>Need Helpers?</label>
    <select name="helpers">
      <option value="0">No helpers needed</option>
      <option value="1">1 Helper (+$25)</option>
      <option value="2">2 Helpers (+$45)</option>
    </select>

    <button type="submit">Get Quote & Book</button>
  </form>

  <p><a href="/">← Back to Home</a></p>
</body>
</html>
