<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Payment Successful - Shurget</title>
  <style>
    body { font-family: system-ui; max-width: 700px; margin: 60px auto; padding: 20px; text-align: center; line-height: 1.6; }
    h1 { color: #ea580c; }
    .success-box { background: #f0fdf4; border: 2px solid #4ade80; border-radius: 12px; padding: 40px; }
  </style>
</head>
<body>
  <div class="success-box">
    <h1>✅ Payment Successful!</h1>
    <p>Your booking has been confirmed.</p>
    <p>A Shurget driver will be assigned shortly and will contact you.</p>
    <p><strong>Order Reference:</strong> <span id="orderId">Loading...</span></p>
  </div>
  <p><a href="/">← Back to Home</a> | <a href="/book">Book Another Haul</a></p>

  <script>
    const urlParams = new URLSearchParams(window.location.search);
    const sessionId = urlParams.get('session_id');
    document.getElementById('orderId').textContent = sessionId ? sessionId.substring(0, 12) + '...' : 'Pending';
  </script>
</body>
</html>
