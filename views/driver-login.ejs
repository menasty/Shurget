<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Driver Login — Shurget</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; }
    body {
      font-family: 'DM Sans', sans-serif;
      background: #0a0a0a;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem 1.5rem;
      position: relative;
      overflow: hidden;
    }

    /* Orange glow */
    body::before {
      content: '';
      position: fixed;
      bottom: -100px;
      right: -100px;
      width: 600px;
      height: 500px;
      background: radial-gradient(ellipse, rgba(234,88,12,.11) 0%, transparent 65%);
      pointer-events: none;
    }

    .login-wrap {
      position: relative;
      z-index: 1;
      width: 100%;
      max-width: 400px;
    }

    /* Brand mark */
    .login-brand {
      text-align: center;
      margin-bottom: 1.75rem;
    }
    .login-brand-img {
      height: 52px;
      width: auto;
      object-fit: contain;
      filter: brightness(1);
    }
    .login-brand-label {
      font-family: 'DM Sans', sans-serif;
      font-size: .72rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: .14em;
      color: rgba(255,255,255,.3);
      margin-top: .6rem;
    }

    /* Card */
    .login-card {
      background: #111;
      border: 1px solid rgba(255,255,255,.09);
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 24px 60px rgba(0,0,0,.55);
    }

    /* Orange top bar */
    .login-card-bar {
      height: 4px;
      background: linear-gradient(90deg, #b84000, #ea580c);
    }

    .login-card-inner { padding: 2.25rem 2rem; }

    .login-card-title {
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.7rem;
      letter-spacing: .08em;
      color: #fff;
      margin-bottom: .2rem;
    }
    .login-card-sub {
      font-size: .82rem;
      color: rgba(255,255,255,.35);
      margin-bottom: 1.75rem;
    }

    /* Error */
    .login-error {
      background: rgba(220,38,38,.1);
      border: 1px solid rgba(220,38,38,.3);
      border-radius: 8px;
      padding: .75rem 1rem;
      font-size: .85rem;
      color: #fca5a5;
      margin-bottom: 1.25rem;
    }

    /* Fields */
    .field-group { margin-bottom: 1.1rem; }
    .field-label {
      display: block;
      font-size: .72rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: .1em;
      color: rgba(255,255,255,.45);
      margin-bottom: .4rem;
    }
    .field-input {
      width: 100%;
      padding: .8rem 1rem;
      background: #0a0a0a;
      border: 1.5px solid rgba(255,255,255,.1);
      border-radius: 8px;
      font-family: 'DM Sans', sans-serif;
      font-size: .95rem;
      color: #fff;
      outline: none;
      transition: border-color .2s, box-shadow .2s;
      -webkit-appearance: none;
    }
    .field-input::placeholder { color: rgba(255,255,255,.22); }
    .field-input:focus {
      border-color: #ea580c;
      box-shadow: 0 0 0 3px rgba(234,88,12,.12);
    }
    .field-hint {
      font-size: .72rem;
      color: rgba(255,255,255,.28);
      margin-top: .35rem;
    }

    /* Submit */
    .login-btn {
      width: 100%;
      padding: .9rem;
      background: #b84000;
      color: #fff;
      border: none;
      border-radius: 8px;
      font-family: 'Bebas Neue', sans-serif;
      font-size: 1.25rem;
      letter-spacing: .1em;
      cursor: pointer;
      transition: background .2s, transform .15s;
      margin-top: .75rem;
    }
    .login-btn:hover { background: #9e3800; transform: translateY(-1px); }
    .login-btn:focus-visible { outline: 2px solid #ea580c; outline-offset: 2px; }

    /* Apply link */
    .apply-link {
      text-align: center;
      margin-top: 1.25rem;
      font-size: .78rem;
      color: rgba(255,255,255,.3);
    }
    .apply-link a {
      color: #ea580c;
      text-decoration: none;
      font-weight: 600;
    }
    .apply-link a:hover { text-decoration: underline; }
  </style>
</head>
<body>
  <div class="login-wrap">
    <div class="login-brand">
      <img src="/images/shurget-logo-nav.png" alt="Shurget" class="login-brand-img">
      <div class="login-brand-label">Driver Portal</div>
    </div>

    <div class="login-card">
      <div class="login-card-bar"></div>
      <div class="login-card-inner">
        <div class="login-card-title">Driver Sign In</div>
        <p class="login-card-sub">Sign in to view jobs, earnings, and your schedule.</p>

        <% if (locals.error) { %>
          <div class="login-error"><%= error %></div>
        <% } %>

        <form method="POST" action="/driver/login">
          <div class="field-group">
            <label class="field-label" for="email">Email Address</label>
            <input
              class="field-input"
              type="email"
              id="email"
              name="email"
              placeholder="you@example.com"
              autocomplete="email"
              required
            />
          </div>

          <div class="field-group">
            <label class="field-label" for="pin">Last 4 digits of your phone</label>
            <input
              class="field-input"
              type="text"
              id="pin"
              name="pin"
              placeholder="e.g. 4521"
              maxlength="4"
              pattern="\d{4}"
              inputmode="numeric"
              autocomplete="off"
              required
            />
            <p class="field-hint">The number you used when applying</p>
          </div>

          <button type="submit" class="login-btn">Sign In →</button>
        </form>
      </div>
    </div>

    <div class="apply-link">
      Not a driver yet? <a href="/drive">Apply now</a>
    </div>
  </div>
</body>
</html>
